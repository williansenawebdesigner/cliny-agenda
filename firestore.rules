rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -- HELPERS --
    function isSignedIn() {
      return request.auth != null;
    }

    function isClinicAdmin(clinicId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clinics/$(clinicId)).data.adminEmail == request.auth.token.email;
    }

    // -- CLINICS --
    match /clinics/{clinicId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.adminEmail == request.auth.token.email;
      allow update: if isClinicAdmin(clinicId);
      allow delete: if isClinicAdmin(clinicId);
    }

    // -- PROFESSIONALS --
    match /professionals/{profId} {
      allow get: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isClinicAdmin(request.resource.data.clinicId);
      allow update, delete: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
    }

    // -- WHATSAPP INSTANCES --
    match /whatsapp_instances/{instanceId} {
      allow get: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isClinicAdmin(request.resource.data.clinicId);
      allow update, delete: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
    }

    // -- WHATSAPP MESSAGES --
    // Backend (Admin SDK) bypasses rules entirely. Front-end uses these.
    match /whatsapp_messages/{messageId} {
      allow get: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
      allow list: if isSignedIn();
      // Webhook on the server uses Admin SDK, so we deny client-side writes here.
      allow create, update, delete: if false;
    }

    // -- PATIENTS --
    match /patients/{patientId} {
      allow get: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isClinicAdmin(request.resource.data.clinicId);
      allow update, delete: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
    }

    // -- APPOINTMENTS --
    match /appointments/{appId} {
      allow get: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isClinicAdmin(request.resource.data.clinicId);
      allow update, delete: if isSignedIn() && isClinicAdmin(resource.data.clinicId);
    }
  }
}
