# =============================================================
# Cliny Agenda — Environment Variables
# =============================================================
#
# Copy this file to `.env.local` for local development.
# In Vercel, set the SAME variables in the project's
# Environment Variables panel (use "Sensitive" for any secret).
#
# IMPORTANT:
#   - Variables prefixed with VITE_  are EXPOSED to the browser
#     (they are bundled into the SPA at build time).
#   - Variables WITHOUT the VITE_ prefix are server-only and
#     can be marked as "Sensitive" in Vercel.
#

# -------- Firebase (client + server) --------
# Browser-exposed (Web App config — already public-safe by Firebase design)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
# Optional: only set if using a non-default Firestore database id
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""

# Server-only mirror (used by /api routes — same values, no VITE_ prefix)
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_APP_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_FIRESTORE_DATABASE_ID=""

# -------- Gemini (AI agent) --------
GEMINI_API_KEY=""

# -------- Evolution API (WhatsApp) --------
EVOLUTION_API_URL=""
EVOLUTION_GLOBAL_API_KEY=""

# Shared secret used to authenticate inbound webhook calls from
# the Evolution API. Generate a random string (e.g. `openssl rand -hex 32`).
# Required in production. The webhook URL will include `?secret=...`.
EVOLUTION_WEBHOOK_SECRET=""

# Public URL of this deployment (used to build the webhook URL when
# creating an Evolution instance). Vercel auto-populates VERCEL_URL,
# so you only need PUBLIC_URL when deploying elsewhere or on a custom domain.
PUBLIC_URL=""
